MVP_ACCESS_CODE=

# LLM polishing + 八维剖析 — DEEPSEEK_API_KEY takes priority over OPENAI_API_KEY if both are set.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 全网检索（Tavily） — 用于在评估结果旁补充行业资料/标准/论文
TAVILY_API_KEY=

BGE_M3_MODEL_NAME=BAAI/bge-m3
BGE_M3_USE_FP16=true
BGE_M3_BATCH_SIZE=8
BGE_M3_MAX_LENGTH=1024
